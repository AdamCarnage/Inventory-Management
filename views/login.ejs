<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log-in</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="valid">
    <div class="header-container">
        <h1 class="title">Business Inventory Login</h1>
    </div>
    <div class="form-container">
        <form action="/" method="POST" id="loginForm" class="login-form">
            <label for="name">Name</label>
            <input type="text" id="username" placeholder="Enter your Name" name="name" required><br>
            <label for="email">Email</label>
            <input type="email" id="e-mail" placeholder="Enter your email" name="email" required><br>
            <label for="pass">Password</label>
            <input type="password" id="pass" placeholder="Enter your password" name="pass" required><br>
            <button type="submit" class="login-button">LOG IN</button>
        </form>
        <button type="submit" class="register-button"><a href="/register" class="register-link">REGISTER</a></button><br>
        <a href="/customerservice" class="forgot-password">Forgot Password? Consult Admin</a>
    </div>
</body>

<%- include('additionals/footer'); -%>
