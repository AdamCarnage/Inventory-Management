<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="valid">
    <div class="header-container">
        <h1 class="title">Business Inventory Register</h1>
    </div>
    <div class="form-container">
    <form action="/register" method="POST" id="loginForm" class="regin">
        <label for="name">First name</label>
        <input type="text" id="username" placeholder="Enter your Name" name="f_name" required><br>
        <label for="name">Last name</label>
        <input type="text" id="username" placeholder="Enter your Name" name="l_name" required><br>
        <label for="name">User name</label>
        <input type="text" id="username" placeholder="Enter your Name" name="name" required><br>
        <label for="email">Email</label>
        <input type="email" id="e-mail" placeholder="Enter your email" name="email" required><br>
        <label for="pass">password</label>
        <input type="password" id="pass" placeholder="Enter your password" name="pass" required><br>
        <button type="submit" class="register-button">REGISTER</button>
        <br>
        <a href="/">Return to Home</a>
    </form>
</div>
</body>


