    <div class="content">
    <h1>Welcome user </h1>
    <br>
    <form action="/home" method="GET">
    <button type="submit">Log out</button>
    </form>
    <p>
        Inventory management apps are invaluable tools for businesses of all sizes. These applications provide a streamlined and efficient way to track, 
        manage, and optimize stock levels and assets. With features like real-time updates, barcode scanning, and reporting analytics, 
        inventory apps empower businesses to make informed decisions, reduce waste, and improve overall operational efficiency. Additionally, 
        they often integrate with point-of-sale systems, allowing for seamless order processing and inventory replenishment. 
        By offering a comprehensive view of stock levels, sales trends, and supplier information, 
        these apps help businesses strike the delicate balance between meeting customer demands and avoiding overstocking. 
        Whether for small retailers or large-scale enterprises, a well-designed inventory management app can be a cornerstone
        in ensuring smoother operations and a healthier bottom line.
    </p>
    <br>


    <!-- adding my goods -->
    <h2>Add new goods Here</h2>
    <div id="popupForm" class="form_item">
        <form action="/home" id="dataForm" method="POST">
            <input type="text" name="item" placeholder="item name" required><br>
            <input type="number" name="Qty" placeholder="Quantity" name="quantity" min="1" max="500" step="1" required><br>
            <select name="category" placeholder="category" required>
                <option value="all">All Categories</option>
                <option value="fruits">fruits</option>
                <option value="sprays">Body spray</option>
                <option value="soft drinks">soft drinks</option>
                <option value="Vegetables">vegies</option>
                <option value="alcohol">liquor</option>
                <option value="baked goods">baked</option>
                <option value="sweets">sweets</option>
                <option value="butter">butter</option>
            </select>
            <br>
            <input type="number" name="cost" placeholder="Price in tsh" required><br>
            <input type="date" name="exp" required pattern="\d{4}-\d{2}-\d{2}" />
            <input type="submit" value="Submit">
        </form>
    </div>

    <!-- table displaying expiring goods -->
    <h2>Near expiring Goods Details</h2>
    <table>
        <thead>
        <tr>
            <th>id</th>
            <th>items</th>
            <th>Qty</th>
            <th>Category</th>
            <th>Price in Tsh</th>
            <th>Expire date</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody id="data-table-body">
        <% if (data && data.length > 0) { %>
            <% data.forEach(item => { %>
                <tr id="goods">
                    <td><%= item.id %></td>
                    <td><%= item.item_name %></td>
                    <td><%= item.item_qty %></td>
                    <td><%= item.item_category %></td>
                    <td><%= item.item_price %></td>
                    <td><%= item.exp_date %></td>
                    <td>
                        <button class="edit-btn" data-id="<%= item.id %>">Edit</button>
                        <button class="delete-btn" data-id="<%= item.id %>">Delete</button>
                    </td>
                </tr>
            <% }); %>
        <% } else { %>
            <tr>
                <td colspan="7">No data available</td>
            </tr>
        <% } %>
    </tbody>
    
    </table>
    <br>

    <!-- table displaying new goods -->
    <h2>New Goods detais</h2>
    <table>
    <thead>
        <tr>
            <th>id</th>
            <th>items</th>
            <th>Qty</th>
            <th>Category</th>
            <th>Price in Tsh</th>
            <th>Expire date</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody id="data-table-body">
        <% data.forEach(item => { %>
            <tr id="goods">
                <td><%= item.id %></td>
                <td><%= item.item_name %></td>
                <td><%= item.item_qty %></td>
                <td><%= item.item_category %></td>
                <td><%= item.item_price %></td>
                <td><%= item.exp_date %></td>
                <td>
                    <button class="edit-btn" data-id="<%= item.id %>">Edit</button>
                    <button class="delete-btn" data-id="<%= item.id %>">Delete</button>
                </td>
            </tr>
        <% }); %>
    </tbody>
    <tbody>
        <tr>
            <td colspan="2">Total:</td>
            <td id="total-qty"></td>
            <td colspan="2" id="total-price"></td>
        </tr>
    </tbody>
    </table>
    <br>

    <div id="confirmationModal" class="modal">
        <div class="modal-content">
          <p>Are you sure you want to delete this item?</p>
          <button id="confirmDelete">Yes</button>
          <button id="cancelDelete">No</button>
        </div>
      </div>
    </div>
    <script>

/*------------------create new Id for produts------------------------*/
document.getElementById('dataForm').addEventListener('submit', function(event) {
    event.preventDefault();

    const randomId = generateRandomId();

    const idInput = document.createElement('input');
    idInput.type = 'hidden';
    idInput.name = 'id';
    idInput.value = randomId;
    this.appendChild(idInput);

    this.submit();
});


function generateRandomId() {
    const max = 9223372036854775807;  
    const randomNum = Math.floor(Math.random() * (max + 1));
    return randomNum;
}


/*------------------add delete btn in all table rows------------------------*/
document.querySelectorAll('.delete-btn').forEach(button => {
    button.addEventListener('click', function() {
        const row = this.closest('tr');
        const rowIndex = row.rowIndex;
        console.log(`Button in row ${rowIndex} was clicked`);
    });
});


/*------------------delete produts using id------------------------*/
document.addEventListener('DOMContentLoaded', () => {
    const deleteButtons = document.querySelectorAll('.delete-btn');

    deleteButtons.forEach(button => {
        button.addEventListener('click', () => {
            const itemId = button.dataset.id;

            const confirmation = confirm('Are you sure you want to delete this item?');

            if (confirmation) {
                fetch(`/delete/${itemId}`, {
                    method: 'DELETE'
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    button.closest('tr').remove();
                })
                .catch(error => console.error('Error:', error));
            }
        });
    });
});


/*------------------Edit produts details using id------------------------*/
document.addEventListener('DOMContentLoaded', () => {
    const editButtons = document.querySelectorAll('.edit-btn');

    editButtons.forEach(button => {
        button.addEventListener('click', () => {
            const itemId = button.dataset.id;
            window.location.href = `/edit/${itemId}`;
        });
    });
});

    </script>
